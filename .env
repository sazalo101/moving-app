# Go to your app → Select "B2C" product → Get credentials below

# Initiator Name (Sandbox: "testapi" | Production: Your organization's initiator username)
MPESA_INITIATOR_NAME=testapi

# Security Credential (Encrypted password - Get from Daraja portal)
# Leave EMPTY for simulation mode (no real money transfer, instant testing)
# For real withdrawals: Click "Generate Security Credential" in Daraja portal
# Format: Long base64 string starting with something like "Ag8B4kJ2cD5eF7gH..."
MPESA_SECURITY_

# B2C Short Code (Sandbox: 600996 | Production: Your organization shortcode)
MPESA_B2C_SHORT_CODE=600996

# Callback URLs (Update with your ngrok/server URL)
# Result URL: Called when B2C transaction succeeds/fails
MPESA_B2C_RESULT_URL=https://duly-recloseable-krish.ngrok-free.dev/api/mpesa/b2c-result

# Timeout URL: Called when B2C transaction times out (no response from M-Pesa)
MPESA_B2C_TIMEOUT_URL=https://duly-recloseable-krish.ngrok-free.dev/api/mpesa/b2c-timeout

